DirectoryIndex index.html

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso a /ai/
    RewriteRule ^ai(/.*)?$ - [F,L]

    # No reescribir archivos o carpetas reales
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirects 301 — URLs antiguas de WordPress
    RewriteRule ^contador-de-palabras/?$ /contadores-de-texto/contador-de-palabras [R=301,L]
    RewriteRule ^contador-de-caracteres/?$ /contadores-de-texto/contador-de-caracteres [R=301,L]
    RewriteRule ^contador-de-emojis/?$ /contadores-de-texto/contador-de-emojis [R=301,L]
    RewriteRule ^contador-de-lineas/?$ /contadores-de-texto/contador-de-lineas [R=301,L]
    RewriteRule ^contador-de-letras/?$ /contadores-de-texto/contador-de-letras [R=301,L]
    RewriteRule ^contador-de-numeros/?$ /contadores-de-texto/contador-de-numeros [R=301,L]
    RewriteRule ^contador-de-parrafos/?$ /contadores-de-texto/contador-de-parrafos [R=301,L]
    RewriteRule ^contador-de-frases/?$ /contadores-de-texto/contador-de-frases [R=301,L]
    RewriteRule ^contador-de-frases-largas/?$ /contadores-de-texto/contador-de-frases-largas [R=301,L]
    RewriteRule ^contador-de-frases-cortas/?$ /contadores-de-texto/contador-de-frases-cortas [R=301,L]
    RewriteRule ^contador-de-palabras-largas/?$ /contadores-de-texto/contador-de-palabras-largas [R=301,L]
    RewriteRule ^contador-de-palabras-cortas/?$ /contadores-de-texto/contador-de-palabras-cortas [R=301,L]
    RewriteRule ^contador-de-palabras-repetidas/?$ /contadores-de-texto/contador-de-palabras-repetidas [R=301,L]
    RewriteRule ^contador-de-palabras-unicas/?$ /contadores-de-texto/contador-de-palabras-unicas [R=301,L]
    RewriteRule ^contador-de-palabras-clave/?$ /contadores-de-texto/contador-de-palabras-clave [R=301,L]
    RewriteRule ^contador-de-densidad-de-palabras/?$ /contadores-de-texto/contador-de-densidad-de-palabras [R=301,L]
    RewriteRule ^contador-de-tiempo-de-lectura/?$ /contadores-de-texto/contador-de-tiempo-de-lectura [R=301,L]
    RewriteRule ^contador-de-tiempo-de-habla/?$ /contadores-de-texto/contador-de-tiempo-de-habla [R=301,L]
    RewriteRule ^contador-de-conectores/?$ /contadores-de-texto/contador-de-conectores [R=301,L]
    RewriteRule ^contador-de-silabas/?$ /contadores-de-texto/contador-de-silabas [R=301,L]
    RewriteRule ^contador-de-urls/?$ /contadores-de-texto/contador-de-urls [R=301,L]
    RewriteRule ^contador-de-menciones/?$ /contadores-de-texto/contador-de-menciones [R=301,L]
    RewriteRule ^contador-de-hashtags/?$ /contadores-de-texto/contador-de-hashtags [R=301,L]
    RewriteRule ^contador-de-parrafos-largos/?$ /contadores-de-texto/contador-de-parrafos-largos [R=301,L]
    RewriteRule ^contador-de-caracteres-sin-espacios/?$ /contadores-de-texto/contador-de-caracteres-sin-espacios [R=301,L]
    RewriteRule ^desarrollo-codificacion/?$ /desarrollo-y-codificacion [R=301,L]
    RewriteRule ^herramienta/inversor-de-texto/?$ /manipulacion-de-texto/invertir-texto [R=301,L]
    RewriteRule ^herramienta/codificador-base64/?$ /desarrollo-y-codificacion/codificador-base64 [R=301,L]
    RewriteRule ^herramienta/extraer-hashtags/?$ /redes-sociales/generador-hashtags-instagram [R=301,L]
    RewriteRule ^convertidor-texto-html/?$ /desarrollo-y-codificacion/formateador-json [R=301,L]
    RewriteRule ^desarrollo-y-codificacion/formateador-xml/?$ /desarrollo-y-codificacion/formateador-json [R=301,L]
    RewriteRule ^herramienta/buscar-palabras-duplicadas/?$ /manipulacion-de-texto/invertir-texto [R=301,L]
    RewriteRule ^manipulacion-de-texto/buscar-palabras-duplicadas/?$ /manipulacion-de-texto/invertir-texto [R=301,L]
    RewriteRule ^sobre-nosotros/?$ /legal/sobre-nosotros [R=301,L]
    RewriteRule ^herramientas-de-escritura/?$ /herramientas-para-estudiantes [R=301,L]
    RewriteRule ^utilidades-de-texto/?$ /utilidades-avanzadas [R=301,L]
    

    # Quitar trailing slash — redirigir a URL sin barra final (301)
    RewriteCond %{REQUEST_URI} ^/(.+)/$
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # Páginas legales: /legal/{slug} → legal/{slug}.html
    RewriteRule ^legal/([^/]+)$ legal/$1.html [L]

    # URL canónica: /{categoria}/{slug} → tools/{categoria}/{slug}.html
    RewriteRule ^([^/]+)/([^/]+)$ tools/$1/$2.html [L]

    # Reglas explícitas para categorías con historial de 404
    RewriteRule ^limpiadores-de-texto$ categories/limpiadores-de-texto.html [L]
    RewriteRule ^manipulacion-de-texto$ categories/manipulacion-de-texto.html [L]
    RewriteRule ^herramientas-para-estudiantes$ categories/herramientas-para-estudiantes.html [L]
    RewriteRule ^utilidades-avanzadas$ categories/utilidades-avanzadas.html [L]

    # URL de categoría: /{categoria} → categories/{categoria}.html
    RewriteRule ^([^/]+)$ categories/$1.html [L]
</IfModule>

# Página de error 404 amigable
ErrorDocument 404 /404.html

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'self'"
</IfModule>

<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType application/javascript .js
    AddType application/xml .xml
    AddType text/plain .txt
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>
